# vllm-nemotron-omni-aeon-ultimate:v1 — 2026-04-30 (canonical / published)
# Source-built vLLM v0.20.0 release commit (88d34c6409, 2026-04-27) targeting
# DGX Spark (GB10 / sm_121a / unified memory) for the Nemotron-3-Nano-Omni-30B-A3B-Reasoning
# model family — including the AEON-7 abliterated/quantized variants:
#   AEON-7/Nemotron-3-Nano-Omni-AEON-Ultimate-Uncensored-BF16
#   AEON-7/Nemotron-3-Nano-Omni-AEON-Ultimate-Uncensored-NVFP4
#
# Why this image exists separately from vllm-aeon-ultimate-dflash (the Qwen3.6 image):
#   - Distinct model family — Nemotron-3-Nano-Omni uses NVIDIA's NemotronH hybrid
#     Mamba2+Attention+MoE architecture (52 layers, "MEMEM*EMEMEM*..." block pattern)
#     plus C-RADIOv2-H vision tower and Parakeet audio encoder. None of these need
#     the Qwen3.5/3.6-specific patches (register_qwen3_5_text, patch_mrope_text_fallback)
#     that the qwen36 image carries.
#   - vLLM v0.20.0 already supports the omni wrapper natively. PR #39747 (merged
#     2026-04-15, in the v0.20.0 release tag) aliases NemotronH_Nano_Omni_Reasoning_V3
#     and NemotronH_Super_Omni_Reasoning_V3 to the existing NemotronH_Nano_VL_V2 class
#     in vllm/model_executor/models/nano_nemotron_vl.py — which already wires up
#     RADIO (vision), Parakeet (audio), mlp1 (projection), and language_model.backbone.*
#     (NemotronH hybrid). No new model code needed; we just verify the registry alias
#     is present at build time.
#   - Spec-decode story is different: Nemotron-3-Nano-Omni uses thinking-mode rather
#     than DFlash drafter (DFlash was Qwen3.6-specific). Native --speculative-config
#     covers the n-gram and lookahead cases vLLM v0.20 supports for NemotronH.
#
# Carry-over patches from the qwen36 image (still relevant):
#   ✓ patch_kv_cache_utils.py — same hybrid linear-attn block_size=None crash on
#     NemotronH (30 Mamba layers among 52 total). Filters None before min(...).
#   ✓ patch_cuda_optional_import.py — RTLD_LAZY workaround for sm_121a builds
#     missing SM100-only mxfp4_experts_quant kernels. Spark-specific.
#   ✓ patch_cudagraph_align.py — defensive spec-decode capture-size alignment.
#     Idempotent — no-op if upstream catches up.
#
# Patches REMOVED from the qwen36 image (not relevant):
#   ✗ register_qwen3_5_text.py — Qwen3.5 registry alias, not needed
#   ✗ patch_mrope_text_fallback.py — Qwen3.5 mRoPE fallback, not needed
#
# New patch:
#   ✓ verify_nemotron_omni_registered.py — build-time assertion that
#     NemotronH_Nano_Omni_Reasoning_V3 + NemotronH_Super_Omni_Reasoning_V3 are aliased
#     and the underlying nano_nemotron_vl + radio + parakeet modules import cleanly.
#     Halts the build loudly if upstream regresses.
#
# Build:  docker build -t ghcr.io/aeon-7/vllm-nemotron-omni-aeon-ultimate:v1 -f Dockerfile.v1 .
# Push:   docker push ghcr.io/aeon-7/vllm-nemotron-omni-aeon-ultimate:v1

FROM ghcr.io/aeon-7/vllm-spark-gemma4-nvfp4-awq:latest

RUN apt-get update && apt-get install -y --no-install-recommends \
      ccache git \
 && rm -rf /var/lib/apt/lists/*

ENV PIP_NO_CACHE_DIR=1 \
    UV_SYSTEM_PYTHON=1 \
    TORCH_CUDA_ARCH_LIST="12.0+PTX" \
    MAX_JOBS=14 \
    NVCC_THREADS=2 \
    CMAKE_BUILD_PARALLEL_LEVEL=14 \
    CCACHE_DIR=/root/.ccache \
    USE_CCACHE=1 \
    CUDA_HOME=/usr/local/cuda \
    PATH=/usr/local/cuda/bin:$PATH \
    ENABLE_NVFP4_SM100=0
    # Note: VLLM_TEST_FORCE_FP8_MARLIN intentionally NOT set.
    # Default behavior selects FLASHINFER_CUTLASS for both Linear and MoE NVFP4 paths,
    # which gives lower TTFT (especially at moderate concurrency) on Nemotron-Omni's
    # 128-expert × top-6 MoE shape. Users who want to opt into the MARLIN MoE backend
    # for ~5-10% higher aggregate throughput at C=8 can override at runtime:
    #   docker run -e VLLM_TEST_FORCE_FP8_MARLIN=1 ...
    # Linear ops always use FlashInferCutlassNvFp4LinearKernel regardless.
    # See bench results in the model card.

RUN python3 -c "import torch; print(f'torch={torch.__version__} CUDA={torch.version.cuda}')" && \
    nvcc --version | tail -1 && \
    ccache --version | head -1

# Pin to vLLM v0.20.0 RELEASE commit (the actual published-release ref, 2026-04-27).
# This is the same commit our qwen36-v3 image uses — stable, audited, contains PR #39747.
ARG VLLM_COMMIT=88d34c6409e9fb3c7b8ca0c04756f061d2099eb1
RUN git clone https://github.com/vllm-project/vllm.git /workspace/vllm-src \
 && cd /workspace/vllm-src \
 && git checkout ${VLLM_COMMIT} \
 && git log -1 --format='vLLM build pin: %H %s'

WORKDIR /workspace/vllm-src

RUN python3 use_existing_torch.py

RUN uv pip install --system -r requirements/build.txt 2>/dev/null || \
    uv pip install --system -r requirements/build/cuda.txt

RUN uv pip install --system --no-build-isolation --no-deps . 2>&1 | tee /tmp/vllm-build.log | tail -100

# FlashInfer v0.6.9 STABLE (2026-04-24).
RUN uv pip uninstall --system flashinfer-python flashinfer-cubin flashinfer-jit-cache 2>/dev/null || true
RUN uv pip install --system --no-deps \
      "flashinfer-python @ git+https://github.com/flashinfer-ai/flashinfer.git@v0.6.9"

# scipy needed by turboquant.codebook (from scipy import integrate, special).
RUN uv pip install --system "scipy>=1.11"
RUN uv pip install --system --no-deps \
      "turboquant @ git+https://github.com/AEON-7/turboquant.git@fix/cuda-graph-safe-qjl-powers"

# transformers ≥ 5.7 — Nemotron-3-Nano-Omni's omni wrapper (NemotronH_Nano_Omni_Reasoning_V3)
# uses transformers 5.x APIs (transformers.utils.output_capturing.capture_outputs,
# transformers.utils.generic.merge_with_config_defaults, transformers.modeling_layers.GradientCheckpointingLayer,
# transformers.utils.import_utils.resolve_internal_import). 5.7 is the version that ships these.
RUN python3 -c "import transformers; print(f'pre-pin transformers={transformers.__version__}')" && \
    uv pip install --system "transformers>=5.7,<6"

# librosa + soundfile — Parakeet audio encoder dependencies (16kHz mel feature extraction).
RUN uv pip install --system "librosa>=0.10" "soundfile>=0.12"

WORKDIR /
RUN rm -rf /workspace/vllm-src

# === Patches (audit notes in header; all idempotent) ===

# Hybrid-attention block_size=None crash filter — NemotronH has 30 Mamba layers among
# 52 total, same crash mode as Qwen3.6 hybrid (same vLLM kv_cache_utils code path).
COPY patches/patch_kv_cache_utils.py /opt/patches/
RUN python3 /opt/patches/patch_kv_cache_utils.py

# RTLD_LAZY for sm_121a builds missing SM100-only mxfp4 kernels — Spark-specific.
COPY patches/patch_cuda_optional_import.py /opt/patches/
RUN python3 /opt/patches/patch_cuda_optional_import.py

# Spec-decode capture-size alignment — defensive, no-op if upstream catches up.
COPY patches/patch_cudagraph_align.py /opt/patches/
RUN python3 /opt/patches/patch_cudagraph_align.py

# === Build-time verification ===

# Nemotron-Omni registry + sub-modules.  Halts build if upstream regresses PR #39747.
COPY patches/verify_nemotron_omni_registered.py /opt/patches/
RUN python3 /opt/patches/verify_nemotron_omni_registered.py

# General version manifest.
RUN python3 -c "\
import torch, vllm, flashinfer, turboquant, transformers, librosa, soundfile; \
print(f'POST vLLM={vllm.__version__}'); \
print(f'POST flashinfer={flashinfer.__version__}'); \
print(f'POST torch={torch.__version__} CUDA={torch.version.cuda}'); \
print(f'POST transformers={transformers.__version__}'); \
print(f'POST turboquant={getattr(turboquant, \"__version__\", \"?\")}'); \
print(f'POST librosa={librosa.__version__}'); \
print(f'POST soundfile={soundfile.__version__}'); \
" && \
    ls /usr/local/lib/python3.12/dist-packages/vllm/_C.abi3.so && \
    echo 'image OK — vllm._C will load at runtime when --gpus all mounts libcuda.so.1'

LABEL org.opencontainers.image.title="vllm-nemotron-omni-aeon-ultimate" \
      org.opencontainers.image.description="AEON-7 vLLM container for Nemotron-3-Nano-Omni-30B-A3B-Reasoning on DGX Spark / GB10. v1: vLLM v0.20.0 release (88d34c6409, 2026-04-27) + FlashInfer v0.6.9 stable + Nemotron-Omni native multimodal support (PR #39747) + 3 sm_121a hybrid-arch patches. Targets the AEON-Ultimate-Uncensored variants (BF16 and NVFP4)." \
      org.opencontainers.image.source="https://github.com/AEON-7/Nemotron-3-Nano-Omni-AEON-Ultimate" \
      org.opencontainers.image.url="https://huggingface.co/AEON-7/Nemotron-3-Nano-Omni-AEON-Ultimate-Uncensored-BF16" \
      org.opencontainers.image.documentation="https://huggingface.co/AEON-7/Nemotron-3-Nano-Omni-AEON-Ultimate-Uncensored-BF16" \
      org.opencontainers.image.version="v1" \
      org.opencontainers.image.base.name="ghcr.io/aeon-7/vllm-spark-gemma4-nvfp4-awq:latest" \
      vllm.compute_capability="sm_120+PTX" \
      vllm.target_hardware="DGX Spark / GB10 / sm_121a" \
      vllm.vllm_commit="88d34c6409e9fb3c7b8ca0c04756f061d2099eb1" \
      vllm.target_model_family="NemotronH_Nano_Omni_Reasoning_V3" \
      vllm.aeon_variants="BF16,NVFP4"
